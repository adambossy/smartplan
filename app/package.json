{
  "name": "smartplan-app",
  "private": true,
  "type": "module",
  "workspaces": ["packages/*"],
  "scripts": {
    "typecheck": "tsc --build",
    "compile-plan": "bun run packages/cli/src/index.ts compile",
    "dev": "bun run --cwd packages/ui dev",
    "build-ui": "bun run --cwd packages/ui build",
    "serve": "bun run packages/cli/src/index.ts serve"
  },
  "devDependencies": {
    "typescript": "^5.6.0"
  }
}
